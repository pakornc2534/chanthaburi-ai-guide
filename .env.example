# Copy this file to .env and fill in the values.
# .env is in .gitignore — never commit it.

# --- Supabase ---
# Get these from your Supabase project: Settings → API
# https://supabase.com/dashboard
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Service role key — SECRET. Bypasses RLS. Server-side only.
# Settings → API → "service_role" → Reveal → Copy
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_SERVICE_ROLE_KEY"

# Vite client-side (browser) — same project, publishable key only
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# --- AI Provider: OpenRouter ---
# Get a key at https://openrouter.ai/keys (free tier available)
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="google/gemini-2.0-flash-lite-001"

# Optional — used in OpenRouter's HTTP-Referer/X-Title headers
# for public ranking on openrouter.ai/rankings
OPENROUTER_SITE_URL="http://localhost:8080"
OPENROUTER_SITE_NAME="TripChan"
